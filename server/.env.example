# Copy to server/.env and fill in values
# Generate admin hash: node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Required in production for signed session cookies
SECRET_KEY=change-me-to-something-long-and-random

# Optional: path to SQLite file (default: server/instance/icecream.db)
# DATABASE_URL=

# Server port (default: 3001)
PORT=3001
